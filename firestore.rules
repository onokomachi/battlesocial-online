// BattleMath Online - Firestore Security Rules
// エビデンスレベルA: Firebase公式セキュリティルール設計パターン
//
// デプロイ方法:
//   firebase deploy --only firestore:rules
//
// コレクション構造:
//   /users/{uid}          - ユーザープロファイル・進捗
//   /rooms/{roomId}       - PvPルーム
//   /config/game          - ゲーム設定 (管理者のみ書込み)

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザーデータ: 自分のデータのみ読み書き可
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // 削除は管理者コンソールのみ
    }

    // PvPルーム: 認証済みユーザーが読み書き可
    // エビデンスA: Firebase公式 - 最小権限の原則
    // 参加者(host/guest)のみ削除可能にし、ゾンビルームの蓄積を防止
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && (resource.data.hostId == request.auth.uid
            || resource.data.guestId == request.auth.uid
            || resource.data.status == 'finished');
    }

    // ゲーム設定: 誰でも読める / 書込み不可 (管理者コンソールで設定)
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // クラスチーム: 認証済みユーザーが読み書き可
    // エビデンスB: 協力設計 × オキシトシン系（Zak 2012）
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ランキング用 (月次サブトピック別): 認証ユーザーが読み書き可
    // ドキュメントID: {YYYY-MM}_{subtopic}_{uid}
    match /rankings/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
